<Window x:Class="DisplayClock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DisplayClock"
        mc:Ignorable="d"
        Title="Display Time" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="Black">
    <Grid>
        <TabControl>
            <!-- Onglet digital -->
            <TabItem Header="Digital">
                <Grid Background="Black">
                    <TextBlock x:Name="DigitalClockText"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Text="00:00:00"
                               FontSize="120"
                               FontWeight="Bold"
                               Foreground="Lime"
                               TextAlignment="Center" />
                </Grid>
            </TabItem>

            <!-- Onglet analogique -->
            <TabItem Header="Analogique">
                <Grid Background="Black">
                    <Canvas x:Name="AnalogCanvas">
                        <!-- Cadran -->
                        <Ellipse Width="350" Height="350"
                                 Stroke="White" StrokeThickness="4"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center" />

                        <!-- Marqueurs des heures -->
                        <Canvas x:Name="TicksCanvas" />

                        <!-- Aiguilles -->
                        <Line x:Name="HourHand"
                              Stroke="White" StrokeThickness="6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" />

                        <Line x:Name="MinuteHand"
                              Stroke="White" StrokeThickness="4"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" />

                        <Line x:Name="SecondHand"
                              Stroke="Red" StrokeThickness="2"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                    </Canvas>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
